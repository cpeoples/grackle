/target

# Local-only evidence / PoC material for the writeup (deliberately vulnerable
# workflows, exploit notes, raw finding corpus). NEVER commit: a live
# .github/workflows file here would try to run, and the material is pre-
# disclosure. Kept out of the repo entirely.
/evidence/

# Hugo docs build artifacts (generated by .hugo/scripts/build_docs.py + hugo)
.hugo/content/
.hugo/public/
.hugo/resources/
.hugo/.hugo_build.lock

# Python bytecode cache from the docs build script
__pycache__/
*.pyc

# Local-only corpus-hunting scripts + the repo trees they fetch. These query
# GitHub/GitLab for live fork-triggerable agent workflows to validate grackle
# against real repos. Kept out of the repo: they fetch third-party code and
# could be used to enumerate exploitable targets.
/hunt/tree/
/hunt/out/
/hunt/*.json
/hunt/

# Local-only pre-disclosure launch material: draft Show HN / news-site posts and
# per-repo security advisories that name currently-unpatched projects. Kept out
# of the repo until coordinated disclosure is complete.
/publish/
